      <column datatype='real' name='[BMI]' role='measure' type='quantitative' />
      <column caption='Risk Category' datatype='string' name='[Calculation_0084687644852224]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Health] = &quot;Bad&quot; THEN &quot;High Risk&quot;&#13;&#10;ELSE &quot;Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_0084687645040641]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 30 THEN &quot;18-29&quot;&#13;&#10;ELSEIF [Age] &lt; 45 THEN &quot;30-44&quot;&#13;&#10;ELSEIF [Age] &lt; 60 THEN &quot;45-59&quot;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;END' />
      </column>
      <column caption='BMI Category' datatype='string' name='[Calculation_0084687645405186]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [BMI] &lt; 18.5 THEN &quot;Underweight&quot;&#13;&#10;ELSEIF [BMI] &lt; 25 THEN &quot;Normal&quot;&#13;&#10;ELSEIF [BMI] &lt; 30 THEN &quot;Overweight&quot;&#13;&#10;ELSE &quot;Obese&quot;&#13;&#10;END' />
      </column>
      <column caption='Blood Pressure Category' datatype='string' name='[Calculation_0084687645659139]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Systolic BP] &lt; 120 THEN &quot;Normal&quot;&#13;&#10;ELSEIF [Systolic BP] &lt; 140 THEN &quot;Pre-Hypertension&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
      </column>
      <column caption='High Risk Count' datatype='integer' name='[Calculation_0084687648804869]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Health] = &quot;Bad&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Low Risk Count' datatype='integer' name='[Calculation_0084687649775622]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Health] = &quot;Good&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Smoker Count' datatype='integer' name='[Calculation_0084687651635207]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Smoker] = TRUE THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Diabetes Count' datatype='integer' name='[Calculation_0084687652065288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Diabetes] = TRUE THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
